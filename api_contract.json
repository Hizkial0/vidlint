{
  "request": {
    "mode": "finished|draft",
    "game": "string",
    "context": "string (optional)",
    "publicId": "string",
    "imageUrlSmall": "string (url)",
    "retinaMetrics": {
      "brightness": "number",
      "contrastStd": "number",
      "dynRange": "number",
      "mobile": {
        "width": "number",
        "dynRange": "number",
        "edgeDensity": "number",
        "pass": "boolean"
      }
    }
  },
  "response": {
    "mode": "finished|draft",
    "score": "integer (0-100)",
    "scoreColor": "string (hex)",
    "verdict": "string",
