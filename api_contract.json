        { "priority": "P3" }
      ]
    },
    "highImpactPlan": {
      "time": "string (e.g. 20-90 min)",
      "fixes": [
        {
          "priority": "P1|P2",
          "pts": "string (+N)",
          "title": "string",
          "measurableFix": "string"
        },
        { "priority": "P2" }
      ],
      "note": "string (optional)"
    },
    "layoutOptions": [
      {
        "label": "A",
        "steps": ["string", "string"]
      },
      {
        "label": "B",
        "steps": ["string", "string"]
      }
    ],
    "copyButtons": [
